{
  "plansDirectory": ".claude/plans",
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Write",
      "Edit",
      "Skill",
      "Bash",
      "Read",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Task",
      "mcp__neo4j-cypher__read_neo4j_cypher",
      "mcp__neo4j-cypher__get_neo4j_schema",
      "mcp__perplexity",
      "mcp__alphavantage",
      "mcp__obsidian",
      "mcp__ibkr-live",
      "mcp__ibkr-paper"
    ],
    "ask": [
      "mcp__neo4j-cypher__write_neo4j_cypher"
    ]
  },
  "env": {
    "CLAUDE_CODE_ENABLE_TASKS": "true",
    "CLAUDE_CODE_TASK_LIST_ID": "earnings-orchestrator",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "MAX_THINKING_TOKENS": "63999"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "/home/faisal/EventMarketDB/.claude/hooks/validate_gx_output.sh"
          },
          {
            "type": "command",
            "command": "/home/faisal/EventMarketDB/.claude/hooks/validate_judge_output.sh"
          },
          {
            "type": "command",
            "command": "python3 /home/faisal/EventMarketDB/.claude/hooks/validate_learning_output.py"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "/home/faisal/EventMarketDB/.claude/hooks/block_env_edits.sh"
          }
        ]
      },
      {
        "matcher": "mcp__neo4j-cypher__write_neo4j_cypher",
        "hooks": [
          {
            "type": "command",
            "command": "/home/faisal/EventMarketDB/.claude/hooks/guard_neo4j_delete.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "/home/faisal/EventMarketDB/.claude/hooks/cleanup_after_ok.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/faisal/EventMarketDB/.claude/hooks/notify_done.sh"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/faisal/EventMarketDB/.claude/hooks/obsidian_capture.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "/home/faisal/EventMarketDB/.claude/hooks/comm_style_post_compact.sh"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/faisal/EventMarketDB/.claude/hooks/comm_style_post_compact.sh"
          }
        ]
      }
    ]
  }
}